# Dependencies
/node_modules/
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Tests and generated output
/coverage/
**/coverage/
**/.next/
/out/
**/dist/
**/build/
*.tsbuildinfo
next-env.d.ts

# Logs and local runtime files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
**/media-uploads/
**/.tmp/

# Local environment and deployment state
.env
.env.*
!.env.example
!**/.env.example
.vercel/

# Local tools
.claude/
.codex/
.agents/
.impeccable/

# Operating-system files and local certificates
.DS_Store
Thumbs.db
*.pem

# Local database clusters, exports, and backups
/database-backups/
/database-local/
/database-exports/
**/pgdata/
**/.pglite/
*.dump
*.dump.gz
*.backup
*.backup.gz
*.pgdump
*.pgbackup
*.sql
*.sql.gz
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal

# Official database migrations are source code and must remain trackable
!packages/database/migrations/
!packages/database/migrations/**/*.sql

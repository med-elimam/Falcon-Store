# ── Falcon Store API — Railway environment ──────────────────────
# لا تضع أسرارًا حقيقية في هذا الملف.

NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# PostgreSQL على Railway (يُحقن تلقائيًا عند ربط قاعدة البيانات)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/railway

# مفتاح توقيع الكوكيز — 32 محرفًا عشوائيًا على الأقل (openssl rand -base64 48)
COOKIE_SECRET=

# أصول الواجهة المسموح بها، مفصولة بفواصل (بدون شرطة مائلة أخيرة)
WEB_ORIGINS=https://www.example.com,https://example.vercel.app

# نطاق الكوكي في الإنتاج عند استخدام نطاق موحد (مثال: .example.com) — اتركه فارغًا في التطوير
COOKIE_DOMAIN=

# مدة الجلسة بالساعات
SESSION_TTL_HOURS=336

# رمز إنشاء حساب المالك الأول — ولّده عشوائيًا، واحذفه من البيئة بعد إنشاء الحساب
BOOTSTRAP_TOKEN=

# مجلد تخزين الصور — اربط Railway Volume على هذا المسار
MEDIA_DIR=/data/media

# الأساس العام لواجهة API (يستخدم لروابط الوسائط المطلقة إن لزم)
PUBLIC_API_BASE=https://api.example.com

# عدد الوكلاء الموثوقين أمام التطبيق (قفزات X-Forwarded-For).
# Railway = وكيل واحد ⇒ 1. اتصال مباشر بلا وكيل ⇒ 0 أو احذف السطر.
# لا تستخدم قيمة كبيرة عشوائياً: كل قفزة زائدة تسمح بتزوير عنوان العميل وتجاوز حد المعدل.
TRUST_PROXY=1

LOG_LEVEL=info

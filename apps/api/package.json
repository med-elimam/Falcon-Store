{
  "name": "@falcon/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:local": "tsx --env-file=.env src/dev-local.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@falcon/config": "*",
    "@falcon/database": "*",
    "@falcon/shared": "*",
    "@falcon/validation": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.6.1",
    "file-type": "^19.6.0",
    "pg": "^8.16.0",
    "sharp": "^0.34.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.6",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.11.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
